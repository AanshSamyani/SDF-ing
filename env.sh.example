#!/usr/bin/env bash
# Copy this file to `env.sh` and fill in your keys, then `source env.sh`.
# `env.sh` is gitignored — never commit real keys.

# OpenAI: used to GENERATE synthetic documents.
export OPENAI_API_KEY="sk-..."

# Tinker (Thinking Machines): used to FINE-TUNE the open model.
export TINKER_API_KEY="..."

# Optional: Weights & Biases for training logs.
# export WANDB_API_KEY="..."

# Optional: keep HuggingFace / dataset caches off the home partition on the
# remote box (C4 mixing downloads can be large).
# export HF_HOME="$PWD/.cache/huggingface"
